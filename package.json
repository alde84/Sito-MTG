{
    "name": "aether-deck",
    "version": "0.0.1",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "build": "turbo build",
        "dev": "turbo dev",
        "lint": "turbo lint",
        "type-check": "turbo type-check",
        "format": "prettier --write \"**/*.{ts,tsx,md}\""
    },
    "devDependencies": {
        "turbo": "^2.0.0",
        "prettier": "^3.3.0",
        "typescript": "^5.5.0"
    },
    "engines": {
        "node": ">=18.0.0",
        "pnpm": ">=9.0.0"
    },
    "packageManager": "pnpm@9.0.0"
}